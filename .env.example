# API Keys
ANTHROPIC_API_KEY=sk-ant-...      # Required for steps 0, 6, 9 (Claude judge / data gen)
HF_TOKEN=hf_...                   # Required for gated models (Gemma 2, etc.)
WANDB_API_KEY=wandb_v1_...        # Optional, enables experiment tracking

# W&B Configuration
WANDB_PROJECT=persona-steering    # W&B project name
# WANDB_DISABLED=true             # Uncomment to disable W&B even if key is set

# Opt-in large artifact uploads
# WANDB_UPLOAD_ACTIVATIONS=true   # Upload activation .pt files (~18GB per model)
# WANDB_UPLOAD_RESPONSES=true     # Upload response .jsonl files (~200MB per model)
